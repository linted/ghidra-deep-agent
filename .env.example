# ── LangSmith (optional) ──────────────────────────────────────────────────────
# Enable to trace every agent run in the LangSmith UI.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=ghidra-deep-agent

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Conversation history is persisted here across sessions (langgraph-checkpoint-mongodb).
MONGODB_URI=mongodb://appuser:changeme@localhost:27017/checkpointing_db?authSource=checkpointing_db
MONGODB_DB=firmware_analysis        # database the checkpointer uses; must be accessible by your user
MONGODB_VECTOR_COLLECTION=re_knowledge  # collection for the vector knowledge base (default: re_knowledge)

# ── Embeddings (for vector knowledge base) ────────────────────────────────────
# provider:model string for embeddings. Supported providers:
#   ollama:<model>       — default; requires Ollama running locally
#   openai:<model>       — requires: uv add langchain-openai
#   huggingface:<model>  — requires: uv add langchain-huggingface
#   cohere:<model>       — requires: uv add langchain-cohere
#   automated:<model>    — MongoDB Atlas Automated Embeddings via Voyage AI;
#                          Atlas generates embeddings server-side, no local
#                          model needed. Requires an Atlas cluster (MONGODB_URI
#                          must point at Atlas, not self-hosted Mongo) with
#                          Voyage AI configured at the Atlas project level.
#
# Examples:
#   EMBED_MODEL=ollama:nomic-embed-text     # pull first: ollama pull nomic-embed-text
#   EMBED_MODEL=openai:text-embedding-3-small
#   EMBED_MODEL=huggingface:BAAI/bge-small-en-v1.5
#   EMBED_MODEL=automated:voyage-4
EMBED_MODEL=ollama:nomic-embed-text

# ── Model ────────────────────────────────────────────────────────────────────
# Any LangChain provider:model string. Examples:
#   Anthropic: anthropic:claude-sonnet-4-6
#   Ollama:    ollama:qwen2.5-coder:32b
MODEL=anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek: set MODEL=deepseek:deepseek-chat (or deepseek-reasoner) and provide the key below.
# DEEPSEEK_API_KEY=sk-...

# ── Agent ────────────────────────────────────────────────────────────────────
# LangGraph recursion limit (default 25 is too low for deep RE sessions).
# RECURSION_LIMIT=10000

# ── Ollama (optional) ─────────────────────────────────────────────────────────
# Only needed if Ollama is not on the default http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# ── Ghidra MCP transport ──────────────────────────────────────────────────────
# Choose ONE transport and configure it below.

# Option A – stdio (default): launch a local MCP bridge as a subprocess.
GHIDRA_MCP_TRANSPORT=stdio
GHIDRA_MCP_COMMAND=ghidra-mcp
GHIDRA_MCP_ARGS=        # extra CLI flags, space-separated

# Option B – Streamable HTTP (remote or local server on a port).
# GHIDRA_MCP_TRANSPORT=http
# GHIDRA_MCP_URL=http://localhost:8080/mcp

# Option C – SSE (server-sent events).
# GHIDRA_MCP_TRANSPORT=sse
# GHIDRA_MCP_URL=http://localhost:8080/mcp

# ── Agent output directory ───────────────────────────────────────────────────
# Directory the agent can read/write files in. Defaults to in-memory storage
# when unset. The path is used as a virtual root (path traversal is blocked).
# AGENT_OUTPUT_DIR=/tmp/ghidra-agent-output

# ── Optional memory file ──────────────────────────────────────────────────────
# Path to an AGENTS.md file loaded into the agent's context every session.
# Use it to record the binary's architecture, key findings, and naming conventions.
# AGENTS_MD=./AGENTS.md

# ── Web UI (ghidra-deep-agent-web) ────────────────────────────────────────────
# Bind address for the browser front-end. Defaults to 0.0.0.0:8000.
# WEB_HOST=0.0.0.0
# WEB_PORT=8000
