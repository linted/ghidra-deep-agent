# ── LangSmith (optional) ──────────────────────────────────────────────────────
# Enable to trace every agent run in the LangSmith UI.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=ghidra-deep-agent

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Conversation history is persisted here across sessions (langgraph-checkpoint-mongodb).
MONGODB_URI=mongodb://appuser:changeme@localhost:27017/checkpointing_db?authSource=checkpointing_db
MONGODB_DB=firmware_analysis        # database the checkpointer uses; must be accessible by your user
MONGODB_VECTOR_COLLECTION=re_knowledge  # collection for the vector knowledge base (default: re_knowledge)
# Registry of resumable sessions backing the TUI /resume command (default: sessions).
# MONGODB_SESSIONS_COLLECTION=sessions
# Cache for read-only Ghidra MCP tools. Repeats with identical args are served
# from Mongo instead of re-running the slow tool. Two tiers: immutable reads
# (TOOLS) expire only by TTL; mutable reads (MUTABLE_TOOLS: decompilation/xrefs/
# data) are additionally flushed per-binary whenever a Ghidra mutation tool
# (rename/comments/types/...) succeeds. Ghidra-GUI edits bypass invalidation —
# set MONGODB_TOOL_CACHE_MUTABLE_TOOLS= (empty) if you edit while the agent runs.
# Set either allowlist empty to disable that tier.
# MONGODB_TOOL_CACHE_COLLECTION=tool_cache
# MONGODB_TOOL_CACHE_TTL=86400
# MONGODB_TOOL_CACHE_TOOLS=search_strings,get_imports,get_exports,get_entry_points,get_binary_info
# MONGODB_TOOL_CACHE_MUTABLE_TOOLS=get_code,xrefs,get_data_at
# MONGODB_TOOL_CACHE_DEBUG=1

# ── Embeddings (for vector knowledge base) ────────────────────────────────────
# provider:model string for embeddings. Supported providers:
#   ollama:<model>       — default; requires Ollama running locally
#   openai:<model>       — requires: uv add langchain-openai
#   huggingface:<model>  — requires: uv add langchain-huggingface
#   cohere:<model>       — requires: uv add langchain-cohere
#   automated:<model>    — MongoDB Atlas Automated Embeddings via Voyage AI;
#                          Atlas generates embeddings server-side, no local
#                          model needed. Requires an Atlas cluster (MONGODB_URI
#                          must point at Atlas, not self-hosted Mongo) with
#                          Voyage AI configured at the Atlas project level.
#
# Examples:
#   EMBED_MODEL=ollama:nomic-embed-text     # pull first: ollama pull nomic-embed-text
#   EMBED_MODEL=openai:text-embedding-3-small
#   EMBED_MODEL=huggingface:BAAI/bge-small-en-v1.5
#   EMBED_MODEL=automated:voyage-4
EMBED_MODEL=ollama:nomic-embed-text

# ── Model ────────────────────────────────────────────────────────────────────
# Any LangChain provider:model string. Examples:
#   Anthropic:  anthropic:claude-sonnet-4-6
#   Ollama:     ollama:qwen2.5-coder:32b
#   OpenRouter: openrouter:anthropic/claude-3.5-sonnet  (one key, many providers)
MODEL=anthropic:claude-sonnet-4-6

# DeepSeek: set MODEL=deepseek:deepseek-chat (or deepseek-reasoner) and provide the key below.
# DEEPSEEK_API_KEY=sk-...

# OpenRouter: set MODEL=openrouter:<model-id> (id as shown on openrouter.ai; must
# support tool calling) and provide the key below. See README "Using OpenRouter".
# OPENROUTER_API_KEY=sk-or-...
# Optional: pin which upstream providers OpenRouter routes each model to. Copy
# openrouter.toml.example to openrouter.toml, or point this at a file.
# OPENROUTER_CONFIG=./openrouter.toml

# Per-agent models (coordinator + sub-agents) are configured in subagents.toml.
# Point AGENT_CONFIG at a different file to override it.
# AGENT_CONFIG=./subagents.toml

# Route the conversation-summarization call (manual /compact AND the auto
# summarizer) to a smaller/cheaper model. Defaults to the main MODEL when unset.
# Summary calls are small (input trimmed to ~4k tokens), so cheap is fine.
# SUMMARY_MODEL=deepseek:deepseek-chat

# Tune the auto-summarizer. The trigger counts the FULL prompt: system prompt +
# tool schemas + message history. Scopes:
#   COMPACT_* — sub-agents. Default: compact at 50k total, keep the most recent
#   10k tokens of history. On by default because models without a langchain
#   context profile otherwise fall back to a 170k trigger that never fires.
#   COMPACT_MAIN_* — the coordinator. Default: stock deepagents thresholds
#   (170k / keep 6 messages without a profile). Its baseline prompt alone is
#   ~60k+, so don't set a trigger below that.
# *_FRACTION knobs need a model with a langchain context profile; most
# provider-proxied models here have none, so prefer the *_TOKENS forms.
# COMPACT_TRIGGER_TOKENS=50000
# COMPACT_KEEP_TOKENS=10000
# COMPACT_KEEP_MESSAGES=10
# COMPACT_TRIGGER_FRACTION=0.7
# COMPACT_MAIN_TRIGGER_TOKENS=100000
# COMPACT_MAIN_KEEP_TOKENS=20000

# ── Model resilience (retry + provider fallback) ──────────────────────────────
# Transient provider errors (5xx / 429 / timeouts) are retried with backoff;
# transient filesystem-tool I/O errors are retried too. Optionally fall back to
# other provider:model(s), tried in order, once the primary's retries run out.
# MODEL_MAX_RETRIES=3
# TOOL_MAX_RETRIES=3
# MODEL_FALLBACK=openrouter:anthropic/claude-3.5-sonnet, anthropic:claude-sonnet-4-6

# ── Agent ────────────────────────────────────────────────────────────────────
# LangGraph recursion limit (default 25 is too low for deep RE sessions).
# RECURSION_LIMIT=10000
# Name this app reports to LangSmith tracing (the root run name). Otherwise every
# run shows up as the langgraph default "LangGraph". Default: ghidra-deep-agent
# APP_NAME=ghidra-deep-agent

# ── Ollama (optional) ─────────────────────────────────────────────────────────
# Only needed if Ollama is not on the default http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# ── Ghidra MCP transport (GhidrAssistMCP) ─────────────────────────────────────
# GhidrAssistMCP is a Ghidra 11.4+/12.1 extension that serves MCP over HTTP.
# Requires: Ghidra running, the GhidrAssistMCP plugin enabled (Window →
# GhidrAssistMCP → MCP server on), and a program open.
#
# NOTE: GhidrAssistMCP defaults to port 8080. If another service already uses
# 8080, change the port in the GhidrAssistMCP control panel and set GHIDRA_MCP_URL
# to match.

# Option A – Streamable HTTP (default).
GHIDRA_MCP_TRANSPORT=http
GHIDRA_MCP_URL=http://localhost:8080/mcp

# Option B – SSE (server-sent events).
# GHIDRA_MCP_TRANSPORT=sse
# GHIDRA_MCP_URL=http://localhost:8080/sse

# ── Async task polling ────────────────────────────────────────────────────────
# GhidrAssistMCP runs slow tools (e.g. get_code) as async tasks; the client polls
# get_task_status until they finish. Polls use exponential backoff: start at
# INTERVAL, grow by FACTOR each poll, cap at MAX. TIMEOUT bounds the wait.
# GHIDRA_ASYNC_POLL_INTERVAL=0.25   # seconds; first (shortest) poll gap
# GHIDRA_ASYNC_POLL_FACTOR=1.6      # multiplier applied after each poll
# GHIDRA_ASYNC_POLL_MAX=2.0         # seconds; cap on the poll gap
# GHIDRA_ASYNC_TIMEOUT=180          # seconds; give up waiting after this

# ── Agent output directory ───────────────────────────────────────────────────
# Directory the agent can read/write files in. Defaults to in-memory storage
# when unset. The path is used as a virtual root (path traversal is blocked).
# AGENT_OUTPUT_DIR=/tmp/ghidra-agent-output

# ── Optional memory file ──────────────────────────────────────────────────────
# Path to an AGENTS.md file loaded into the agent's context every session.
# Use it to record the binary's architecture, key findings, and naming conventions.
# AGENTS_MD=./AGENTS.md
